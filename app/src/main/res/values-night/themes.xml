<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!--
        В тёмной теме statusBar тоже тёмный.
        windowLightStatusBar = false — иконки статусбара белые.
    -->
    <style name="Theme.Farme" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="colorPrimary">@color/green_primary</item>
        <item name="colorPrimaryDark">@color/green_dark</item>
        <item name="colorAccent">@color/orange_accent</item>
        <item name="android:statusBarColor">@color/bg_screen</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowBackground">@color/bg_screen</item>
        <item name="buttonStyle">@style/AppButtonStyle</item>
        <item name="materialButtonStyle">@style/AppButtonStyle</item>
    </style>

    <style name="Theme.Farme.Splash" parent="Theme.Farme">
        <item name="android:windowBackground">@color/green_dark</item>
        <item name="android:statusBarColor">@color/green_dark</item>
    </style>

    <style name="Theme.Farme.Auth" parent="Theme.Farme">
        <item name="android:windowBackground">@color/bg_card</item>
        <item name="android:statusBarColor">@color/bg_card</item>
    </style>

    <style name="Theme.Farme.Admin" parent="Theme.Farme">
        <item name="android:statusBarColor">@color/green_dark</item>
    </style>

    <style name="Theme.Farme.Chat" parent="Theme.Farme">
        <item name="android:windowSoftInputMode">adjustResize</item>
    </style>

    <style name="AppButtonStyle" parent="Widget.AppCompat.Button">
        <item name="android:backgroundTint">@null</item>
        <item name="android:stateListAnimator">@null</item>
        <item name="android:textAllCaps">false</item>
    </style>

</resources>