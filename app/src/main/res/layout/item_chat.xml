<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="?attr/selectableItemBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        android:paddingVertical="10dp">

        <!-- Круглый аватар -->
        <TextView android:id="@+id/tvChatAvatar"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:gravity="center"
            android:text="А"
            android:textSize="19sp"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:background="@drawable/bg_avatar_green_circle"
            android:layout_marginEnd="12dp"/>

        <!-- Текстовый блок -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <!-- Имя + Время -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">
                <TextView android:id="@+id/tvChatName"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textSize="15sp"
                    android:textColor="@color/text_primary"
                    android:textStyle="bold"
                    android:maxLines="1"
                    android:ellipsize="end"/>
                <TextView android:id="@+id/tvChatTime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="12sp"
                    android:textColor="@color/text_hint"
                    android:layout_marginStart="8dp"/>
            </LinearLayout>

            <!-- Название товара -->
            <TextView android:id="@+id/tvListingTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:textColor="@color/green_primary"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end"
                android:layout_marginTop="1dp"
                android:visibility="gone"/>

            <!-- Последнее сообщение + бейдж -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="3dp">
                <TextView android:id="@+id/tvLastMessage"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textSize="13sp"
                    android:textColor="@color/text_secondary"
                    android:maxLines="1"
                    android:ellipsize="end"/>
                <TextView android:id="@+id/tvUnreadBadge"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:gravity="center"
                    android:textSize="11sp"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    android:background="@drawable/bg_avatar_green_circle"
                    android:layout_marginStart="6dp"
                    android:visibility="gone"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Превью товара -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardListingPhoto"
            android:layout_width="58dp"
            android:layout_height="58dp"
            android:layout_marginStart="10dp"
            app:cardCornerRadius="8dp"
            app:cardElevation="0dp"
            android:visibility="gone">
            <ImageView android:id="@+id/ivListingPhoto"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"/>
        </androidx.cardview.widget.CardView>

    </LinearLayout>

    <!-- Разделитель -->
    <View
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        android:layout_marginStart="74dp"
        android:background="#1A000000"/>

</LinearLayout>
