<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_screen">

    <!-- Шапка -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        android:paddingVertical="16dp"
        android:background="@color/bg_card"
        android:fitsSystemWindows="true">
        <TextView
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:text="‹"
            android:textSize="28sp"
            android:textColor="@color/text_primary"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"/>
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/settings_title"
            android:textSize="18sp"
            android:textColor="@color/text_primary"
            android:textStyle="bold"
            android:layout_marginStart="8dp"/>
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- ── ВНЕШНИЙ ВИД ── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/settings_section_appearance"
                android:textSize="11sp"
                android:textColor="@color/text_hint"
                android:textStyle="bold"
                android:letterSpacing="0.08"
                android:layout_marginBottom="8dp"/>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/bg_card">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- Тёмная тема -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="16dp">
                        <TextView
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:text="🌙"
                            android:textSize="17sp"
                            android:gravity="center"
                            android:background="@color/green_surface"
                            android:layout_marginEnd="12dp"/>
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/settings_dark_theme"
                            android:textSize="15sp"
                            android:textColor="@color/text_primary"/>
                        <androidx.appcompat.widget.SwitchCompat
                            android:id="@+id/switchDarkTheme"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:thumbTint="@color/green_primary"
                            android:trackTint="#BBBBBB"/>
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/divider"
                        android:layout_marginHorizontal="16dp"/>

                    <!-- Язык -->
                    <LinearLayout
                        android:id="@+id/itemLanguage"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="16dp"
                        android:clickable="true" android:focusable="true"
                        android:background="?attr/selectableItemBackground">
                        <TextView
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:text="🌐"
                            android:textSize="17sp"
                            android:gravity="center"
                            android:background="@color/green_surface"
                            android:layout_marginEnd="12dp"/>
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Язык / Language"
                            android:textSize="15sp"
                            android:textColor="@color/text_primary"/>
                        <TextView
                            android:id="@+id/tvLanguageValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Русский"
                            android:textSize="13sp"
                            android:textColor="@color/text_hint"
                            android:layout_marginEnd="6dp"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="›"
                            android:textSize="20sp"
                            android:textColor="@color/text_hint"/>
                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ── РЕГИОН ── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/settings_section_region"
                android:textSize="11sp"
                android:textColor="@color/text_hint"
                android:textStyle="bold"
                android:letterSpacing="0.08"
                android:layout_marginBottom="8dp"/>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/bg_card">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- Регион -->
                    <LinearLayout
                        android:id="@+id/itemRegion"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="16dp"
                        android:clickable="true" android:focusable="true"
                        android:background="?attr/selectableItemBackground">
                        <TextView
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:text="📍"
                            android:textSize="17sp"
                            android:gravity="center"
                            android:background="@color/green_surface"
                            android:layout_marginEnd="12dp"/>
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/field_region"
                            android:textSize="15sp"
                            android:textColor="@color/text_primary"/>
                        <TextView
                            android:id="@+id/tvRegionValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Бишкек"
                            android:textSize="13sp"
                            android:textColor="@color/text_hint"
                            android:layout_marginEnd="6dp"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="›"
                            android:textSize="20sp"
                            android:textColor="@color/text_hint"/>
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/divider"
                        android:layout_marginHorizontal="16dp"/>

                    <!-- Валюта -->
                    <LinearLayout
                        android:id="@+id/itemCurrency"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="16dp"
                        android:clickable="true" android:focusable="true"
                        android:background="?attr/selectableItemBackground">
                        <TextView
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:text="💰"
                            android:textSize="17sp"
                            android:gravity="center"
                            android:background="@color/green_surface"
                            android:layout_marginEnd="12dp"/>
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/settings_currency"
                            android:textSize="15sp"
                            android:textColor="@color/text_primary"/>
                        <TextView
                            android:id="@+id/tvCurrencyValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="сом (KGS)"
                            android:textSize="13sp"
                            android:textColor="@color/text_hint"
                            android:layout_marginEnd="6dp"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="›"
                            android:textSize="20sp"
                            android:textColor="@color/text_hint"/>
                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ── УВЕДОМЛЕНИЯ ── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/settings_section_notifications"
                android:textSize="11sp"
                android:textColor="@color/text_hint"
                android:textStyle="bold"
                android:letterSpacing="0.08"
                android:layout_marginBottom="8dp"/>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/bg_card">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- Push -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="16dp">
                        <TextView
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:text="🔔"
                            android:textSize="17sp"
                            android:gravity="center"
                            android:background="@color/green_surface"
                            android:layout_marginEnd="12dp"/>
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/settings_push_notifications"
                            android:textSize="15sp"
                            android:textColor="@color/text_primary"/>
                        <androidx.appcompat.widget.SwitchCompat
                            android:id="@+id/switchPush"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:checked="true"
                            android:thumbTint="@color/green_primary"
                            android:trackTint="#BBBBBB"/>
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/divider"
                        android:layout_marginHorizontal="16dp"/>

                    <!-- Сообщения -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="16dp">
                        <TextView
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:text="💬"
                            android:textSize="17sp"
                            android:gravity="center"
                            android:background="@color/green_surface"
                            android:layout_marginEnd="12dp"/>
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/settings_new_messages"
                            android:textSize="15sp"
                            android:textColor="@color/text_primary"/>
                        <androidx.appcompat.widget.SwitchCompat
                            android:id="@+id/switchMessages"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:checked="true"
                            android:thumbTint="@color/green_primary"
                            android:trackTint="#BBBBBB"/>
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/divider"
                        android:layout_marginHorizontal="16dp"/>

                    <!-- Цены в избранном -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="16dp">
                        <TextView
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:text="🤍"
                            android:textSize="17sp"
                            android:gravity="center"
                            android:background="@color/green_surface"
                            android:layout_marginEnd="12dp"/>
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/settings_price_changes"
                            android:textSize="15sp"
                            android:textColor="@color/text_primary"/>
                        <androidx.appcompat.widget.SwitchCompat
                            android:id="@+id/switchPrices"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:checked="false"
                            android:thumbTint="@color/green_primary"
                            android:trackTint="#BBBBBB"/>
                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ── ПРИВАТНОСТЬ ── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/settings_section_privacy"
                android:textSize="11sp"
                android:textColor="@color/text_hint"
                android:textStyle="bold"
                android:letterSpacing="0.08"
                android:layout_marginBottom="8dp"/>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/bg_card">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- Чёрный список -->
                    <LinearLayout
                        android:id="@+id/itemBlacklist"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="16dp"
                        android:clickable="true" android:focusable="true"
                        android:background="?attr/selectableItemBackground">
                        <TextView
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:text="🚫"
                            android:textSize="17sp"
                            android:gravity="center"
                            android:background="@color/green_surface"
                            android:layout_marginEnd="12dp"/>
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/settings_blacklist"
                            android:textSize="15sp"
                            android:textColor="@color/text_primary"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="›"
                            android:textSize="20sp"
                            android:textColor="@color/text_hint"/>
                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ── ВЫХОД ── -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/bg_card">
                <LinearLayout
                    android:id="@+id/btnLogout"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:gravity="center"
                    android:clickable="true" android:focusable="true"
                    android:background="?attr/selectableItemBackground">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/btn_logout_account"
                        android:textSize="15sp"
                        android:textColor="@color/red_error"
                        android:textStyle="bold"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Версия -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Farme v1.0.0"
                android:textSize="12sp"
                android:textColor="@color/text_hint"
                android:gravity="center"
                android:layout_marginBottom="24dp"/>

        </LinearLayout>
    </ScrollView>
</LinearLayout>