<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    app:cardCornerRadius="14dp"
    app:cardElevation="1dp"
    app:cardBackgroundColor="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="12dp">

        <!-- Фото -->
        <FrameLayout
            android:layout_width="90dp"
            android:layout_height="80dp"
            android:layout_marginEnd="12dp">

            <ImageView
                android:id="@+id/ivRowPhoto"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:background="#F3F4F6"/>

            <!-- Бейдж ТОП -->
            <TextView
                android:id="@+id/rowBadgeTop"
                android:layout_width="wrap_content"
                android:layout_height="18dp"
                android:layout_margin="4dp"
                android:text="⚡"
                android:textSize="11sp"
                android:gravity="center"
                android:paddingHorizontal="4dp"
                android:background="#FEF3C7"
                android:visibility="gone"/>
        </FrameLayout>

        <!-- Текст -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvRowTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Название объявления"
                android:textSize="14sp"
                android:textColor="#111827"
                android:textStyle="bold"
                android:maxLines="2"
                android:ellipsize="end"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="4dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📍"
                    android:textSize="11sp"/>
                <TextView
                    android:id="@+id/tvRowRegion"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Чуй · 24 км"
                    android:textSize="12sp"
                    android:textColor="#6B7280"
                    android:layout_marginStart="2dp"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="6dp">

                <TextView
                    android:id="@+id/tvRowPrice"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="145 000 сом"
                    android:textSize="15sp"
                    android:textColor="#2D6A4F"
                    android:textStyle="bold"/>

                <!-- Рейтинг + паспорт -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">
                    <TextView
                        android:id="@+id/tvRowPassport"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="✓"
                        android:textSize="14sp"
                        android:textColor="#2D6A4F"
                        android:visibility="gone"
                        android:layout_marginEnd="6dp"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="★"
                        android:textSize="13sp"
                        android:textColor="#F59E0B"/>
                    <TextView
                        android:id="@+id/tvRowRating"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="4.9"
                        android:textSize="12sp"
                        android:textColor="#374151"
                        android:textStyle="bold"
                        android:layout_marginStart="2dp"/>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>