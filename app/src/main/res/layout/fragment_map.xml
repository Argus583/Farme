<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F2F5F2">

    <!-- Шапка -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:background="@color/green_primary" android:paddingHorizontal="16dp"
        android:paddingVertical="14dp" android:fitsSystemWindows="true">
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="@string/map_listings_title" android:textSize="18sp"
            android:textColor="#FFFFFF" android:textStyle="bold"/>
    </LinearLayout>

    <!-- Чипы категорий -->
    <HorizontalScrollView android:layout_width="match_parent" android:layout_height="wrap_content"
        android:background="#FFFFFF" android:paddingVertical="8dp"
        android:paddingHorizontal="12dp" android:scrollbars="none">
        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:orientation="horizontal">
            <TextView android:id="@+id/mapChipAll"
                android:layout_width="wrap_content" android:layout_height="32dp"
                android:text="Все" android:gravity="center" android:paddingHorizontal="14dp"
                android:textSize="12sp" android:textColor="#FFFFFF"
                android:background="#2D6A4F" android:layout_marginEnd="8dp"
                android:clickable="true" android:focusable="true"/>
            <TextView android:id="@+id/mapChipSkot"
                android:layout_width="wrap_content" android:layout_height="32dp"
                android:text="🐄 Скот" android:gravity="center" android:paddingHorizontal="14dp"
                android:textSize="12sp" android:textColor="#2D6A4F"
                android:background="@drawable/bg_chip_default" android:layout_marginEnd="8dp"
                android:clickable="true" android:focusable="true"/>
            <TextView android:id="@+id/mapChipZerno"
                android:layout_width="wrap_content" android:layout_height="32dp"
                android:text="🌾 Зерно" android:gravity="center" android:paddingHorizontal="14dp"
                android:textSize="12sp" android:textColor="#2D6A4F"
                android:background="@drawable/bg_chip_default" android:layout_marginEnd="8dp"
                android:clickable="true" android:focusable="true"/>
            <TextView android:id="@+id/mapChipOvoshi"
                android:layout_width="wrap_content" android:layout_height="32dp"
                android:text="🥬 Овощи" android:gravity="center" android:paddingHorizontal="14dp"
                android:textSize="12sp" android:textColor="#2D6A4F"
                android:background="@drawable/bg_chip_default" android:layout_marginEnd="8dp"
                android:clickable="true" android:focusable="true"/>
            <TextView android:id="@+id/mapChipFrukty"
                android:layout_width="wrap_content" android:layout_height="32dp"
                android:text="🍎 Фрукты" android:gravity="center" android:paddingHorizontal="14dp"
                android:textSize="12sp" android:textColor="#2D6A4F"
                android:background="@drawable/bg_chip_default" android:layout_marginEnd="8dp"
                android:clickable="true" android:focusable="true"/>
            <TextView android:id="@+id/mapChipPtitsa"
                android:layout_width="wrap_content" android:layout_height="32dp"
                android:text="🐔 Птица" android:gravity="center" android:paddingHorizontal="14dp"
                android:textSize="12sp" android:textColor="#2D6A4F"
                android:background="@drawable/bg_chip_default"
                android:clickable="true" android:focusable="true"/>
        </LinearLayout>
    </HorizontalScrollView>

    <!-- Карта -->
    <FrameLayout android:id="@+id/mapContainer"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"/>

    <!-- Нижняя панель — ближайшие объявления -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical" android:background="#FFFFFF"
        android:elevation="8dp">

        <!-- Заголовок панели -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical"
            android:paddingHorizontal="16dp" android:paddingTop="12dp" android:paddingBottom="8dp">
            <TextView android:id="@+id/tvMapNearbyTitle"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:text="Ближайшие · 0 объявлений"
                android:textSize="13sp" android:textColor="#0A1F14" android:textStyle="bold"/>
            <TextView android:id="@+id/btnMapShowAll"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="@string/btn_show_all" android:textSize="12sp" android:textColor="#2D6A4F"
                android:textStyle="bold" android:clickable="true" android:focusable="true"/>
        </LinearLayout>

        <!-- Список ближайших -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerMapListings"
            android:layout_width="match_parent"
            android:layout_height="130dp"
            android:orientation="horizontal"
            android:paddingHorizontal="12dp"
            android:clipToPadding="false"/>

    </LinearLayout>
</LinearLayout>