<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="wrap_content"
    android:orientation="horizontal" android:gravity="start"
    android:paddingHorizontal="12dp" android:paddingVertical="3dp">
    <LinearLayout
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bg_msg_other"
        android:paddingHorizontal="12dp" android:paddingTop="8dp" android:paddingBottom="6dp"
        android:maxWidth="260dp">
        <TextView android:id="@+id/tvMessageText"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:textSize="14sp"
            android:textColor="@color/msg_other_text"
            android:lineSpacingMultiplier="1.3"/>
        <TextView android:id="@+id/tvMessageTime"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:textSize="10sp"
            android:textColor="@color/msg_time_text"
            android:layout_gravity="end" android:layout_marginTop="2dp"/>
    </LinearLayout>
</LinearLayout>