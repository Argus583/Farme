<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:background="@color/bg_screen" android:scrollbars="none">
    <LinearLayout android:layout_width="match_parent"
        android:layout_height="wrap_content" android:orientation="vertical">

        <!-- Шапка -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical"
            android:background="@color/green_primary"
            android:paddingHorizontal="16dp" android:paddingVertical="16dp"
            android:fitsSystemWindows="true">
            <TextView android:id="@+id/btnBack"
                android:layout_width="40dp" android:layout_height="40dp"
                android:text="‹" android:textSize="28sp" android:textColor="#FFFFFF"
                android:gravity="center" android:clickable="true" android:focusable="true"/>
            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:text="@string/edit_profile_title"
                android:textSize="18sp" android:textColor="#FFFFFF"
                android:textStyle="bold" android:layout_marginStart="8dp"/>
        </LinearLayout>

        <!-- Аватар -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:gravity="center"
            android:background="@color/bg_card" android:paddingVertical="24dp"
            android:layout_marginBottom="12dp">
            <FrameLayout android:layout_width="80dp" android:layout_height="80dp"
                android:layout_marginBottom="12dp">
                <TextView android:id="@+id/tvAvatarInitials"
                    android:layout_width="80dp" android:layout_height="80dp"
                    android:text="А" android:textSize="30sp" android:textColor="#FFFFFF"
                    android:textStyle="bold" android:gravity="center"
                    android:background="@color/green_primary"/>
                <ImageView android:id="@+id/ivAvatar"
                    android:layout_width="80dp" android:layout_height="80dp"
                    android:scaleType="centerCrop" android:visibility="gone"/>
            </FrameLayout>
            <LinearLayout android:id="@+id/btnChangeAvatar"
                android:layout_width="wrap_content" android:layout_height="36dp"
                android:gravity="center" android:background="@drawable/bg_chip_default"
                android:paddingHorizontal="16dp"
                android:clickable="true" android:focusable="true">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="@string/btn_change_photo" android:textSize="13sp"
                    android:textColor="@color/green_primary" android:textStyle="bold"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Поля -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:background="@color/bg_card"
            android:padding="16dp" android:layout_marginBottom="12dp">

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="@string/name_surname" android:textSize="12sp"
                android:textColor="@color/text_hint" android:textStyle="bold"
                android:layout_marginBottom="6dp"/>
            <EditText android:id="@+id/etName"
                android:layout_width="match_parent" android:layout_height="50dp"
                android:background="@drawable/bg_input" android:paddingHorizontal="14dp"
                android:textSize="15sp" android:textColor="@color/text_primary"
                android:inputType="textPersonName|textCapWords"
                android:layout_marginBottom="16dp"/>

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="@string/method_phone" android:textSize="12sp"
                android:textColor="@color/text_hint" android:textStyle="bold"
                android:layout_marginBottom="6dp"/>
            <EditText android:id="@+id/etPhone"
                android:layout_width="match_parent" android:layout_height="50dp"
                android:background="@drawable/bg_input" android:paddingHorizontal="14dp"
                android:textSize="15sp" android:textColor="@color/text_secondary"
                android:inputType="phone" android:enabled="false"
                android:layout_marginBottom="4dp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="@string/phone_cannot_change"
                android:textSize="11sp" android:textColor="@color/text_hint"
                android:layout_marginBottom="16dp"/>

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="@string/field_region" android:textSize="12sp"
                android:textColor="@color/text_hint" android:textStyle="bold"
                android:layout_marginBottom="6dp"/>
            <Spinner android:id="@+id/spinnerRegion"
                android:layout_width="match_parent" android:layout_height="50dp"
                android:background="@drawable/bg_input" android:paddingHorizontal="14dp"/>
        </LinearLayout>

        <!-- Кнопка сохранить -->
        <LinearLayout android:id="@+id/btnSave"
            android:layout_width="match_parent" android:layout_height="52dp"
            android:gravity="center" android:background="@color/green_primary"
            android:layout_marginHorizontal="16dp" android:layout_marginBottom="24dp"
            android:clickable="true" android:focusable="true">
            <ProgressBar android:id="@+id/pbSave"
                android:layout_width="20dp" android:layout_height="20dp"
                android:indeterminateTint="#FFFFFF"
                android:layout_marginEnd="10dp" android:visibility="gone"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="@string/action_save" android:textSize="16sp"
                android:textColor="#FFFFFF" android:textStyle="bold"/>
        </LinearLayout>
    </LinearLayout>
</ScrollView>