<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FFFFFF"
    android:fitsSystemWindows="true">

    <!-- Зелёная шапка -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="220dp"
        android:orientation="vertical"
        android:gravity="center"
        android:background="@drawable/gradient_header_green">

        <FrameLayout
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:background="@drawable/bg_logo_circle"
            android:layout_marginBottom="14dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="🌾"
                android:textSize="40sp"/>
        </FrameLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Farme"
            android:textSize="32sp"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:letterSpacing="0.05"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/app_tagline"
            android:textSize="14sp"
            android:textColor="#B4DEC0"
            android:layout_marginTop="4dp"/>
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:scrollbars="none"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="24dp"
            android:paddingTop="32dp"
            android:paddingBottom="40dp">

            <TextView
                android:id="@+id/tvFormTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/welcome"
                android:textSize="26sp"
                android:textColor="#111827"
                android:textStyle="bold"
                android:layout_marginBottom="6dp"/>

            <TextView
                android:id="@+id/tvFormSubtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/login_subtitle"
                android:textSize="14sp"
                android:textColor="#6B7280"
                android:layout_marginBottom="28dp"/>

            <!-- Табы Вход / Регистрация -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:orientation="horizontal"
                android:background="@drawable/bg_tab_container"
                android:padding="4dp"
                android:layout_marginBottom="24dp">

                <TextView
                    android:id="@+id/tabLogin"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="@string/login"
                    android:textSize="14sp"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    android:background="@drawable/bg_tab_active"
                    android:clickable="true"
                    android:focusable="true"/>

                <TextView
                    android:id="@+id/tabRegister"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="@string/register"
                    android:textSize="14sp"
                    android:textColor="#6B7280"
                    android:textStyle="bold"
                    android:background="@android:color/transparent"
                    android:clickable="true"
                    android:focusable="true"/>
            </LinearLayout>

            <!-- Метод: Телефон / Email -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:orientation="horizontal"
                android:layout_marginBottom="20dp">

                <LinearLayout
                    android:id="@+id/methodPhone"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:background="@drawable/bg_method_active"
                    android:layout_marginEnd="6dp"
                    android:clickable="true"
                    android:focusable="true">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📱"
                        android:textSize="14sp"
                        android:layout_marginEnd="6dp"/>
                    <TextView
                        android:id="@+id/methodPhoneLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/method_phone"
                        android:textSize="13sp"
                        android:textColor="#0A1F14"
                        android:textStyle="bold"/>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/methodEmail"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:background="@drawable/bg_method_inactive"
                    android:clickable="true"
                    android:focusable="true">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="✉"
                        android:textSize="14sp"
                        android:layout_marginEnd="6dp"/>
                    <TextView
                        android:id="@+id/methodEmailLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Email"
                        android:textSize="13sp"
                        android:textColor="#6B7280"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Поле телефона -->
            <LinearLayout
                android:id="@+id/loginPhoneGroup"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/phone"
                    android:textSize="12sp"
                    android:textColor="#374151"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:orientation="horizontal"
                    android:background="@drawable/bg_input_premium">

                    <LinearLayout
                        android:id="@+id/countryCodeBtn"
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="14dp"
                        android:clickable="true"
                        android:focusable="true">
                        <TextView
                            android:id="@+id/tvCountryFlag"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🇰🇬"
                            android:textSize="18sp"
                            android:layout_marginEnd="6dp"/>
                        <TextView
                            android:id="@+id/tvCountryCode"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="+996"
                            android:textSize="15sp"
                            android:textColor="#111827"
                            android:textStyle="bold"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="▾"
                            android:textSize="12sp"
                            android:textColor="#9CA3AF"
                            android:layout_marginStart="4dp"/>
                    </LinearLayout>

                    <View
                        android:layout_width="1dp"
                        android:layout_height="match_parent"
                        android:layout_marginVertical="14dp"
                        android:background="#E5E7EB"/>

                    <EditText
                        android:id="@+id/etLoginPhone"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:hint="700 123 456"
                        android:textColorHint="#9CA3AF"
                        android:textSize="15sp"
                        android:textColor="#111827"
                        android:inputType="phone"
                        android:background="@null"
                        android:paddingHorizontal="14dp"
                        android:maxLength="15"
                        android:singleLine="true"/>
                </LinearLayout>

                <TextView
                    android:id="@+id/tvLoginPhoneError"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="12sp"
                    android:textColor="#DC2626"
                    android:layout_marginTop="6dp"
                    android:visibility="gone"/>
            </LinearLayout>

            <!-- Email поле -->
            <LinearLayout
                android:id="@+id/loginEmailGroup"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="16dp"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/email_address_label"
                    android:textSize="12sp"
                    android:textColor="#374151"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp"/>

                <EditText
                    android:id="@+id/etLoginEmail"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:hint="example@mail.com"
                    android:textColorHint="#9CA3AF"
                    android:textSize="15sp"
                    android:textColor="#111827"
                    android:inputType="textEmailAddress"
                    android:background="@drawable/bg_input_premium"
                    android:paddingHorizontal="16dp"
                    android:singleLine="true"/>

                <TextView
                    android:id="@+id/tvLoginEmailError"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="12sp"
                    android:textColor="#DC2626"
                    android:layout_marginTop="6dp"
                    android:visibility="gone"/>
            </LinearLayout>

            <!-- Пароль (для email-режима) -->
            <LinearLayout
                android:id="@+id/loginPasswordGroup"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="16dp"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="8dp">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/password"
                        android:textSize="12sp"
                        android:textColor="#374151"
                        android:textStyle="bold"/>
                    <TextView
                        android:id="@+id/btnForgotPassword"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/forgot_password_short"
                        android:textSize="12sp"
                        android:textColor="#27AE60"
                        android:textStyle="bold"
                        android:clickable="true"
                        android:focusable="true"/>
                </LinearLayout>

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="56dp">
                    <EditText
                        android:id="@+id/etLoginPassword"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:hint="@string/hint_enter_password"
                        android:textColorHint="#9CA3AF"
                        android:textSize="15sp"
                        android:textColor="#111827"
                        android:inputType="textPassword"
                        android:background="@drawable/bg_input_premium"
                        android:paddingStart="16dp"
                        android:paddingEnd="50dp"
                        android:singleLine="true"/>
                    <TextView
                        android:id="@+id/btnTogglePass"
                        android:layout_width="48dp"
                        android:layout_height="match_parent"
                        android:layout_gravity="end"
                        android:gravity="center"
                        android:text="👁"
                        android:textSize="18sp"
                        android:clickable="true"
                        android:focusable="true"/>
                </FrameLayout>

                <TextView
                    android:id="@+id/tvLoginPasswordError"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="12sp"
                    android:textColor="#DC2626"
                    android:layout_marginTop="6dp"
                    android:visibility="gone"/>
            </LinearLayout>

            <!-- Запомнить меня -->
            <LinearLayout
                android:id="@+id/rememberGroup"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="20dp">
                <CheckBox
                    android:id="@+id/cbRemember"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="true"
                    android:buttonTint="#27AE60"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/remember_me"
                    android:textSize="13sp"
                    android:textColor="#374151"
                    android:layout_marginStart="6dp"/>
            </LinearLayout>

            <!-- Главная кнопка -->
            <LinearLayout
                android:id="@+id/btnPrimary"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:orientation="horizontal"
                android:gravity="center"
                android:background="@drawable/bg_btn_primary_premium"
                android:elevation="2dp"
                android:clickable="true"
                android:focusable="true">

                <ProgressBar
                    android:id="@+id/pbBtnLoading"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:indeterminateTint="#FFFFFF"
                    android:layout_marginEnd="10dp"
                    android:visibility="gone"/>

                <TextView
                    android:id="@+id/tvBtnPrimary"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/login"
                    android:textSize="16sp"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    android:letterSpacing="0.02"/>
            </LinearLayout>

            <TextView
                android:id="@+id/tvFormError"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="13sp"
                android:textColor="#DC2626"
                android:gravity="center"
                android:layout_marginTop="12dp"
                android:visibility="gone"/>

            <TextView
                android:id="@+id/tvPhoneHint"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/phone_verification_hint"
                android:textSize="12sp"
                android:textColor="#9CA3AF"
                android:gravity="center"
                android:layout_marginTop="16dp"/>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#F3F4F6"
                android:layout_marginVertical="24dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/security_badge"
                android:textSize="11sp"
                android:textColor="#9CA3AF"
                android:gravity="center"/>
        </LinearLayout>
    </ScrollView>
</LinearLayout>