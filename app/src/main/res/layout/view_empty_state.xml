<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="48dp">
    <TextView android:id="@+id/tvEmptyIcon"
        android:layout_width="80dp" android:layout_height="80dp"
        android:text="📭" android:textSize="42sp" android:gravity="center"
        android:background="#F3F4F6" android:layout_marginBottom="16dp"/>
    <TextView android:id="@+id/tvEmptyTitle"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="@string/empty_nothing_found"
        android:textSize="17sp" android:textColor="#111827"
        android:textStyle="bold" android:layout_marginBottom="8dp"/>
    <TextView android:id="@+id/tvEmptySubtitle"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="@string/empty_state_hint"
        android:textSize="13sp" android:textColor="#9CA3AF"
        android:gravity="center" android:lineSpacingMultiplier="1.4"
        android:layout_marginBottom="24dp"/>
    <LinearLayout android:id="@+id/btnEmptyAction"
        android:layout_width="wrap_content" android:layout_height="44dp"
        android:gravity="center" android:background="#2D6A4F"
        android:paddingHorizontal="24dp"
        android:clickable="true" android:focusable="true"
        android:visibility="gone">
        <TextView android:id="@+id/tvEmptyAction"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="@string/btn_add_listing_full"
            android:textSize="14sp" android:textColor="#FFFFFF" android:textStyle="bold"/>
    </LinearLayout>
</LinearLayout>