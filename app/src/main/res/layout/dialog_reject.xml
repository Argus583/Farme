<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="wrap_content"
    android:orientation="vertical" android:padding="24dp"
    android:background="@color/bg_card">

    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="@string/dialog_reject_title" android:textSize="18sp"
        android:textColor="#1B2A3B" android:textStyle="bold"/>

    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="@string/dialog_reject_prompt" android:textSize="13sp"
        android:textColor="@color/text_secondary" android:layout_marginTop="12dp"/>

    <!-- Быстрые причины -->
    <TextView android:id="@+id/reasonInvalidDocs"
        android:layout_width="match_parent" android:layout_height="44dp"
        android:text="@string/reason_invalid_docs"
        android:textSize="14sp" android:textColor="@color/text_primary"
        android:gravity="center_vertical" android:paddingHorizontal="12dp"
        android:background="@drawable/bg_chip_default"
        android:layout_marginTop="8dp"
        android:clickable="true" android:focusable="true"/>

    <TextView android:id="@+id/reasonFakeInfo"
        android:layout_width="match_parent" android:layout_height="44dp"
        android:text="@string/reason_fake_info"
        android:textSize="14sp" android:textColor="@color/text_primary"
        android:gravity="center_vertical" android:paddingHorizontal="12dp"
        android:background="@drawable/bg_chip_default"
        android:layout_marginTop="8dp"
        android:clickable="true" android:focusable="true"/>

    <TextView android:id="@+id/reasonNoVetCert"
        android:layout_width="match_parent" android:layout_height="44dp"
        android:text="@string/reason_no_vet_cert"
        android:textSize="14sp" android:textColor="@color/text_primary"
        android:gravity="center_vertical" android:paddingHorizontal="12dp"
        android:background="@drawable/bg_chip_default"
        android:layout_marginTop="8dp"
        android:clickable="true" android:focusable="true"/>

    <TextView android:id="@+id/reasonOther"
        android:layout_width="match_parent" android:layout_height="44dp"
        android:text="@string/reason_other"
        android:textSize="14sp" android:textColor="@color/text_primary"
        android:gravity="center_vertical" android:paddingHorizontal="12dp"
        android:background="@drawable/bg_chip_default"
        android:layout_marginTop="8dp"
        android:clickable="true" android:focusable="true"/>

    <!-- Своя причина -->
    <EditText android:id="@+id/etCustomReason"
        android:layout_width="match_parent" android:layout_height="80dp"
        android:hint="@string/dialog_reject_hint"
        android:inputType="textMultiLine" android:gravity="top"
        android:background="@drawable/bg_input"
        android:padding="12dp" android:textSize="14sp"
        android:layout_marginTop="12dp"
        android:visibility="gone"/>

    <!-- Кнопки -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:layout_marginTop="16dp">

        <Button
            android:id="@+id/btnCancelReject"
            android:layout_width="0dp" android:layout_height="48dp" android:layout_weight="1"
            android:text="@string/btn_cancel" android:textSize="14sp" android:textColor="@color/text_secondary"
            android:background="@drawable/bg_chip_default" android:backgroundTint="@null"
            android:layout_marginEnd="8dp" android:stateListAnimator="@null"/>

        <Button android:id="@+id/btnConfirmReject"
            android:layout_width="0dp" android:layout_height="48dp" android:layout_weight="1"
            android:text="@string/btn_reject" android:textSize="14sp" android:textColor="#FFFFFF"
            android:background="#E74C3C" android:backgroundTint="@null"
            android:stateListAnimator="@null"/>
    </LinearLayout>
</LinearLayout>