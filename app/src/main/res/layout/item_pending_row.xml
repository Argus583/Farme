<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="wrap_content"
    android:layout_marginBottom="8dp" app:cardCornerRadius="11dp" app:cardElevation="1dp">

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical" android:padding="10dp">

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical">
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical">
                <TextView android:id="@+id/tvPendingTitle" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:textSize="13sp"
                    android:textColor="#0A0F0D" android:textStyle="bold" android:maxLines="1"
                    android:ellipsize="end"/>
                <TextView android:id="@+id/tvPendingSub" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:textSize="10sp"
                    android:textColor="#7A8F7E" android:layout_marginTop="2dp"/>
            </LinearLayout>
            <TextView android:id="@+id/tvPendingBadge" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:text="@string/badge_new"
                android:textSize="8sp" android:textColor="#D97706" android:textStyle="bold"
                android:paddingHorizontal="7dp" android:paddingVertical="3dp"
                android:background="#FEF3C7"/>
        </LinearLayout>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:layout_marginTop="8dp">
            <TextView android:id="@+id/btnPendingView"
                android:layout_width="0dp" android:layout_height="34dp" android:layout_weight="1"
                android:text="@string/btn_view_item" android:gravity="center" android:textSize="11sp"
                android:textColor="#2E6B46" android:background="#EFF8F1"
                android:layout_marginEnd="4dp" android:clickable="true" android:focusable="true"/>
            <TextView android:id="@+id/btnPendingApprove"
                android:layout_width="0dp" android:layout_height="34dp" android:layout_weight="1"
                android:text="@string/btn_approve" android:gravity="center" android:textSize="11sp"
                android:textColor="#FFFFFF" android:background="#3D8C5A"
                android:layout_marginEnd="4dp" android:clickable="true" android:focusable="true"/>
            <TextView android:id="@+id/btnPendingReject"
                android:layout_width="34dp" android:layout_height="34dp"
                android:text="✕" android:gravity="center" android:textSize="13sp"
                android:textColor="#FFFFFF" android:background="#DC2626"
                android:clickable="true" android:focusable="true"/>
        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>