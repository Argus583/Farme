<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="oval">

    <gradient
        android:type="linear"
        android:angle="135"
        android:startColor="#66FFFFFF"
        android:centerColor="#33FFFFFF"
        android:endColor="#1AFFFFFF"/>

    <stroke
        android:width="1dp"
        android:color="#55FFFFFF"/>

    <size
        android:width="72dp"
        android:height="72dp"/>

    <padding
        android:left="8dp"
        android:top="8dp"
        android:right="8dp"
        android:bottom="8dp"/>

</shape>