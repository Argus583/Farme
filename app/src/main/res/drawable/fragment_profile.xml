<?xml version="1.0" encoding="utf-8"?>
<androidx.swiperefreshlayout.widget.SwipeRefreshLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/swipeRefresh"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_screen">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scrollbars="none"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Зелёная шапка -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/gradient_header_green"
                android:paddingTop="20dp"
                android:paddingBottom="40dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:orientation="horizontal"
                    android:paddingHorizontal="16dp"
                    android:gravity="center_vertical">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Профиль"
                        android:textSize="20sp"
                        android:textColor="#FFFFFF"
                        android:textStyle="bold"/>
                    <TextView
                        android:id="@+id/btnSettings"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:gravity="center"
                        android:text="⚙"
                        android:textSize="20sp"
                        android:textColor="#FFFFFF"
                        android:clickable="true"
                        android:focusable="true"/>
                </LinearLayout>

                <FrameLayout
                    android:layout_width="100dp"
                    android:layout_height="100dp"
                    android:layout_gravity="center"
                    android:layout_marginTop="16dp">
                    <ImageView
                        android:id="@+id/imgAvatar"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        android:background="@drawable/bg_avatar_simple"/>
                    <TextView
                        android:id="@+id/tvAvatarInitials"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:textSize="36sp"
                        android:textColor="@color/green_primary"
                        android:textStyle="bold"
                        android:background="@drawable/bg_avatar_simple"/>
                </FrameLayout>

                <TextView
                    android:id="@+id/tvUserName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="Имя пользователя"
                    android:textSize="20sp"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    android:layout_marginTop="14dp"/>

                <TextView
                    android:id="@+id/tvRegion"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="📍 Регион"
                    android:textSize="13sp"
                    android:textColor="#B4DEC0"
                    android:layout_marginTop="4dp"/>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="10dp">
                    <TextView
                        android:id="@+id/tvRating"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="★ 0.0"
                        android:textSize="16sp"
                        android:textColor="#FFFFFF"
                        android:textStyle="bold"
                        android:layout_marginEnd="6dp"/>
                    <TextView
                        android:id="@+id/tvReviewsCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="(0 отзывов)"
                        android:textSize="13sp"
                        android:textColor="#B4DEC0"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Статистика -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="-20dp"
                android:paddingHorizontal="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:background="@drawable/bg_card_simple"
                    android:elevation="2dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">
                        <TextView
                            android:id="@+id/statListings"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textSize="22sp"
                            android:textColor="@color/green_primary"
                            android:textStyle="bold"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Объявлений"
                            android:textSize="11sp"
                            android:textColor="@color/text_secondary"
                            android:layout_marginTop="2dp"/>
                    </LinearLayout>

                    <View android:layout_width="1dp" android:layout_height="match_parent"
                        android:background="@color/divider" android:layout_marginVertical="8dp"/>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">
                        <TextView
                            android:id="@+id/statSold"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textSize="22sp"
                            android:textColor="@color/green_primary"
                            android:textStyle="bold"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Продано"
                            android:textSize="11sp"
                            android:textColor="@color/text_secondary"
                            android:layout_marginTop="2dp"/>
                    </LinearLayout>

                    <View android:layout_width="1dp" android:layout_height="match_parent"
                        android:background="@color/divider" android:layout_marginVertical="8dp"/>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">
                        <TextView
                            android:id="@+id/statReviews"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textSize="22sp"
                            android:textColor="@color/green_primary"
                            android:textStyle="bold"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Отзывов"
                            android:textSize="11sp"
                            android:textColor="@color/text_secondary"
                            android:layout_marginTop="2dp"/>
                    </LinearLayout>
                </LinearLayout>
            </FrameLayout>

            <!-- Кнопка редактирования -->
            <LinearLayout
                android:id="@+id/btnEditProfile"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_btn_outline_green"
                android:clickable="true"
                android:focusable="true">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="✎"
                    android:textSize="14sp"
                    android:textColor="@color/green_primary"
                    android:layout_marginEnd="8dp"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Редактировать профиль"
                    android:textSize="14sp"
                    android:textColor="@color/green_primary"
                    android:textStyle="bold"/>
            </LinearLayout>

            <!-- Меню действий -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="20dp"
                android:background="@drawable/bg_card_simple"
                android:elevation="1dp">

                <include layout="@layout/item_profile_menu_row" android:id="@+id/rowMyListings"/>
                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="@color/divider" android:layout_marginHorizontal="16dp"/>
                <include layout="@layout/item_profile_menu_row" android:id="@+id/rowFavorites"/>
                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="@color/divider" android:layout_marginHorizontal="16dp"/>
                <include layout="@layout/item_profile_menu_row" android:id="@+id/rowReviews"/>
                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="@color/divider" android:layout_marginHorizontal="16dp"/>
                <include layout="@layout/item_profile_menu_row" android:id="@+id/rowNotifications"/>
            </LinearLayout>

            <!-- Настройки -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_card_simple"
                android:elevation="1dp">

                <include layout="@layout/item_profile_menu_row" android:id="@+id/rowSettings"/>
                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="@color/divider" android:layout_marginHorizontal="16dp"/>
                <include layout="@layout/item_profile_menu_row" android:id="@+id/rowSupport"/>
                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="@color/divider" android:layout_marginHorizontal="16dp"/>
                <include layout="@layout/item_profile_menu_row" android:id="@+id/rowAbout"/>
            </LinearLayout>

            <!-- Выход -->
            <LinearLayout
                android:id="@+id/btnLogout"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="16dp"
                android:background="@drawable/bg_logout_btn"
                android:clickable="true"
                android:focusable="true">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Выйти из аккаунта"
                    android:textSize="14sp"
                    android:textColor="@color/red_error"
                    android:textStyle="bold"/>
            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="Farme · Санарип Дыйкан"
                android:textSize="11sp"
                android:textColor="@color/text_hint"
                android:layout_marginBottom="20dp"/>

        </LinearLayout>
    </ScrollView>
</androidx.swiperefreshlayout.widget.SwipeRefreshLayout>
